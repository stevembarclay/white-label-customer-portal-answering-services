# Supabase
NEXT_PUBLIC_SUPABASE_URL=           # Your Supabase project URL (from project settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Your Supabase anon/public key (from project settings → API)
SUPABASE_SERVICE_ROLE_KEY=          # Your Supabase service role key (server-side only — keep secret, used by seed script)

# OpenAI
OPENAI_API_KEY=                     # Your OpenAI API key (used by /api/answering-service/coach and /api/answering-service/dashboard-coach)
OPENAI_MODEL=                       # Optional: AI model to use (defaults to gpt-4o-mini). e.g. gpt-4o, gpt-4-turbo

# Cal.com (optional — only needed if using the concierge booking flow in the setup wizard)
NEXT_PUBLIC_CAL_LINK=               # Your Cal.com link slug (e.g. your-org/onboarding). Defaults to 'your-username/onboarding' if unset.

# Support contact (shown in the dashboard AI assistant system prompt)
NEXT_PUBLIC_SUPPORT_EMAIL=          # Support email shown in dashboard AI (e.g. support@yourcompany.com)
NEXT_PUBLIC_SUPPORT_PHONE=          # Support phone shown in dashboard AI (e.g. +1-800-555-0000)

# Deployment mode
# Set to 'true' for standalone / self-hosted deployments where you don't use per-module
# access gating. Auth is still enforced — only the enabled_modules database check is skipped.
# Leave unset (or 'false') if you're using multi-tenant module gating.
STANDALONE_MODE=true

# CORS (optional — comma-separated list of allowed origins for the coach API routes)
ALLOWED_ORIGINS=http://localhost:3000

# Operator white-label configuration
PORTAL_NAME="Answering Service Portal"
PORTAL_LOGO_URL=""
PORTAL_BRAND_COLOR="#3b82f6"
PORTAL_SUPPORT_EMAIL="support@example.com"
